FROM python:3.11-slim

WORKDIR /app

# 安裝系統依賴
RUN apt-get update && apt-get install -y libpq-dev gcc

# 安裝 Python 套件
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 複製程式碼
COPY . .

# 啟動指令
CMD ["python", "main.py"]
# ... 前面維持不變 ...
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]