# ============================================================
# CAXN Platform 環境變數設定範本
# 複製此檔案為 .env 並填入真實設定值
# ============================================================

# ---- 資料庫 ----
DB_HOST=db
DB_NAME=caxn_platform
DB_USER=admin
DB_PASS=your_strong_password_here
DB_PORT=5432

# ---- JWT 設定 ----
JWT_SECRET=your_very_long_random_jwt_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

# ---- Google Gemini AI ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- 前端 API 位址（生產環境改為真實 domain）----
VITE_API_BASE=http://localhost:8000

# ---- 平台設定 ----
AI_DIAGNOSTIC_FEE=10
UPLOAD_MAX_SIZE_MB=500

# ---- 郵件通知（SendGrid 或 SMTP 二選一）----
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=CAXN Platform
# --- SMTP 備援（Gmail 或自架 SMTP）---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# ---- 綠界 ECPay 金流（測試環境）----
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_RETURN_URL=https://your-domain.com/api/payment/ecpay/callback
ECPAY_CLIENT_BACK=https://your-domain.com
SITE_URL=https://your-domain.com
# 點數兌換率（1 元台幣 = 1 點）
POINT_RATE=1.0

# ---- 綠界 ECPay 正式環境（上線時替換）----
# ECPAY_MERCHANT_ID=your_real_merchant_id
# ECPAY_HASH_KEY=your_real_hash_key
# ECPAY_HASH_IV=your_real_hash_iv
# ECPAY_API_URL=https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5

# ---- 雲端儲存（Cloud Run 部署必填）----
# STORAGE_PROVIDER=gcs
# GCS_BUCKET=caxn-uploads
# GCS_PROJECT=your-gcp-project-id
