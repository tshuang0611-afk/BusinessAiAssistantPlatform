# ============================================================
# CAXN Platform 環境變數設定範本
# 複製此檔案為 .env 並填入真實設定值
# ============================================================

# ---- 資料庫 ----
DB_HOST=db
DB_NAME=caxn_platform
DB_USER=admin
DB_PASS=your_strong_password_here
DB_PORT=5432

# ---- JWT 設定 ----
JWT_SECRET=your_very_long_random_jwt_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

# ---- Google Gemini AI ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- 前端 API 位址（生產環境改為真實 domain）----
VITE_API_BASE=http://localhost:8000

# ---- 平台設定 ----
AI_DIAGNOSTIC_FEE=10
UPLOAD_MAX_SIZE_MB=500

# ---- 郵件通知（未來擴充用）----
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password

# ---- 雲端儲存（未來擴充用，目前用本地 Volume）----
# STORAGE_PROVIDER=local  # local | gcs | s3
# GCS_BUCKET=your-bucket-name
# AWS_S3_BUCKET=your-bucket-name
